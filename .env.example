# Copy this file to .env and fill in. Do NOT commit the real .env.

# --- Telegram (from BotFather) ---
# 1. In Telegram, message @BotFather → /newbot → copy the token here.
# 2. Send your new bot any message, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    and copy the chat.id value.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- API endpoints (defaults are fine) ---
POLY_DATA_API=https://data-api.polymarket.com
POLY_GAMMA_API=https://gamma-api.polymarket.com
